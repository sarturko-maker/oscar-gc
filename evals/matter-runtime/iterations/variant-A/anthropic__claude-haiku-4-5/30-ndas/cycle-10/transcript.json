                        "text": "<!-- FILE: src/adeu/templates/markdown_ui.html -->\n<!DOCTYPE html>\n<html>\n\n<head>\n    <meta charset=\"utf-8\">\n    <title>Adeu Markdown UI</title>\n    <meta name=\"color-scheme\" content=\"light dark\">\n    <link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\n    <link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin>\n    <link\n        href=\"https://fonts.googleapis.com/css2?family=Jost:wght@400;500;600&family=Lora:ital,wght@0,600;1,600&display=swap\"\n        rel=\"stylesheet\">\n    <style>\n        :root {\n            --brand-sand: #e8c0a1;\n            --brand-sand-light: #f2d9c7;\n            --brand-sand-dark: #d4a882;\n            --brand-mint: #e6f3f0;\n            --brand-mint-dark: #c9e4de;\n            --brand-navy: #1a2a2c;\n            --brand-navy-light: #2a3a3c;\n            --brand-mauve: #dacad2;\n            --neutral-50: #fafafa;\n            --neutral-100: #f5f5f5;\n            --neutral-200: #e5e5e5;\n            --neutral-300: #d9d9d9;\n            --neutral-600: #555969;\n            --neutral-800: #1e2028;\n            --neutral-900: #171717;\n            --font-lora: 'Lora', Georgia, serif;\n            --font-jost: 'Jost', system-ui, -apple-system, BlinkMacSystemFont, sans-serif;\n            --bg-body: var(--neutral-50);\n            --bg-card: #ffffff;\n            --border-card: var(--neutral-200);\n            --text-main: var(--neutral-600);\n            --text-heading: var(--brand-navy);\n            --bg-blockquote: rgba(232, 192, 161, 0.15);\n        }\n\n        @media (prefers-color-scheme: dark) {\n            :root {\n                --bg-body: var(--neutral-900);\n                --bg-card: var(--brand-navy);\n                --border-card: var(--brand-navy-light);\n                --text-main: rgba(255, 255, 255, 0.85);\n                --text-heading: #ffffff;\n                --bg-blockquote: rgba(232, 192, 161, 0.1);\n                --neutral-100: var(--brand-navy-light);\n            }\n        }\n\n        html,\n        body {\n            margin: 0;\n            padding: 0;\n            box-sizing: border-box;\n            background-color: transparent;\n        }\n\n        body {\n            font-family: var(--font-jost);\n            color: var(--text-main);\n            line-height: 1.6;\n            -webkit-font-smoothing: antialiased;\n            padding: 16px;\n        }\n\n        .adeu-card {\n            background-color: var(--bg-card);\n            border: 1px solid var(--border-card);\n            border-radius: 12px;\n            overflow: hidden;\n            display: flex;\n            flex-direction: column;\n        }\n\n        .navbar {\n            flex-shrink: 0;\n            background-color: var(--bg-card);\n            padding: 16px 32px;\n            border-bottom: 1px solid var(--border-card);\n            display: flex;\n            align-items: center;\n            justify-content: space-between;\n            position: relative;\n        }\n\n        .logo-container {\n            display: flex;\n            align-items: center;\n            flex: 1;\n        }\n\n        .nav-title {\n            position: absolute;\n            left: 50%;\n            transform: translateX(-50%);\n            font-family: var(--font-lora);\n            font-weight: 600;\n            color: var(--text-heading);\n            font-size: 1.1rem;\n            white-space: nowrap;\n            overflow: hidden;\n            text-overflow: ellipsis;\n            max-width: 40%;\n            text-align: center;\n        }\n\n        .nav-actions {\n            display: flex;\n            align-items: center;\n            justify-content: flex-end;\n            flex: 1;\n        }\n\n        #copy-btn {\n            display: none;\n            align-items: center;\n            gap: 6px;\n            background: transparent;\n            border: none;\n            color: var(--text-main);\n           