tent-wrapper::-webkit-scrollbar-track {\n            background: transparent;\n        }\n\n        .content-wrapper::-webkit-scrollbar-thumb {\n            background-color: var(--border-card);\n            border-radius: 4px;\n        }\n\n        #app {\n            padding: 32px;\n            display: flow-root;\n        }\n\n        .fade-overlay {\n            position: absolute;\n            bottom: 0;\n            left: 0;\n            right: 0;\n            height: 80px;\n            background: linear-gradient(to bottom, rgba(255, 255, 255, 0), var(--bg-card));\n            pointer-events: none;\n            display: none;\n        }\n\n        @media (prefers-color-scheme: dark) {\n            .fade-overlay {\n                background: linear-gradient(to bottom, rgba(26, 42, 44, 0), var(--bg-card));\n            }\n        }\n\n        .toggle-container {\n            flex-shrink: 0;\n            display: none;\n            justify-content: center;\n            align-items: center;\n            padding: 12px;\n            border-top: 1px solid var(--border-card);\n            background-color: var(--bg-card);\n        }\n\n        #toggle-btn {\n            background: transparent;\n            border: none;\n            color: var(--brand-sand-dark);\n            font-family: var(--font-jost);\n            font-weight: 600;\n            font-size: 0.95rem;\n            cursor: pointer;\n            display: flex;\n            align-items: center;\n            gap: 6px;\n            padding: 8px 16px;\n            border-radius: 6px;\n            transition: all 0.2s ease;\n        }\n\n        #toggle-btn:hover {\n            color: var(--text-heading);\n            background: var(--neutral-100);\n        }\n\n        @media (prefers-color-scheme: dark) {\n            #toggle-btn:hover {\n                background: var(--brand-navy-light);\n            }\n        }\n\n        #toggle-icon {\n            transition: transform 0.3s ease;\n        }\n\n        h1,\n        h2,\n        h3,\n        h4 {\n            font-family: var(--font-lora);\n            color: var(--text-heading);\n            font-weight: 600;\n            letter-spacing: -0.02em;\n            margin-top: 1.5em;\n            margin-bottom: 0.5em;\n        }\n\n        h1 {\n            font-size: 2.25rem;\n            border-bottom: 1px solid var(--border-card);\n            padding-bottom: 0.3em;\n            margin-top: 0;\n        }\n\n        h2 {\n            font-size: 1.75rem;\n        }\n\n        h3 {\n            font-size: 1.25rem;\n        }\n\n        a {\n            color: var(--brand-sand-dark);\n            text-decoration: none;\n            border-bottom: 1px solid transparent;\n            transition: border 0.2s ease;\n        }\n\n        a:hover {\n            border-bottom-color: var(--brand-sand-dark);\n        }\n\n        strong {\n            font-weight: 600;\n            color: var(--text-heading);\n        }\n\n        ul,\n        ol {\n            padding-left: 1.5rem;\n            margin-bottom: 1rem;\n        }\n\n        li {\n            margin-bottom: 0.5rem;\n        }\n\n        blockquote {\n            border-left: 4px solid var(--brand-sand);\n            padding: 12px 20px;\n            margin: 24px 0;\n            color: var(--text-main);\n            background: var(--bg-blockquote);\n            border-radius: 0 8px 8px 0;\n            font-style: italic;\n        }\n\n        code {\n            font-family: ui-monospace, SFMono-Regular, Consolas, \"Liberation Mono\", Menlo, monospace;\n            font-size: 0.85em;\n            background: var(--neutral-100);\n            color: var(--brand-sand-dark);\n            padding: 0.2em 0.4em;\n            border-radius: 4px;\n        }\n\n        pre code {\n            display: block;\n            padding: 16px;\n            background: var(--neutral-900);\n            color: #e5e5e5;\n            border-radius: 8px;\n            overflow-x: auto