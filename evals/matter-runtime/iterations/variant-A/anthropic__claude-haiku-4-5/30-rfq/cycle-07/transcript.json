                        "text": "<!-- FILE: src/adeu/templates/markdown_ui.html -->\n<!DOCTYPE html>\n<html>\n\n<head>\n    <meta charset=\"utf-8\">\n    <title>Adeu Markdown UI</title>\n    <meta name=\"color-scheme\" content=\"light dark\">\n    <link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\n    <link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin>\n    <link\n        href=\"https://fonts.googleapis.com/css2?family=Jost:wght@400;500;600&family=Lora:ital,wght@0,600;1,600&display=swap\"\n        rel=\"stylesheet\">\n    <style>\n        :root {\n            --brand-sand: #e8c0a1;\n            --brand-sand-light: #f2d9c7;\n            --brand-sand-dark: #d4a882;\n            --brand-mint: #e6f3f0;\n            --brand-mint-dark: #c9e4de;\n            --brand-navy: #1a2a2c;\n            --brand-navy-light: #2a3a3c;\n            --brand-mauve: #dacad2;\n            --neutral-50: #fafafa;\n            --neutral-100: #f5f5f5;\n            --neutral-200: #e5e5e5;\n            --neutral-300: #d9d9d9;\n            --neutral-600: #555969;\n            --neutral-800: #1e2028;\n            --neutral-900: #171717;\n            --font-lora: 'Lora', Georgia, serif;\n            --font-jost: 'Jost', system-ui, -apple-system, BlinkMacSystemFont, sans-serif;\n            --bg-body: var(--neutral-50);\n            --bg-card: #ffffff;\n            --border-card: var(--neutral-200);\n            --text-main: var(--neutral-600);\n            --text-heading: var(--brand-navy);\n            --bg-blockquote: rgba(232, 192, 161, 0.15);\n        }\n\n        @media (prefers-color-scheme: dark) {\n            :root {\n                --bg-body: var(--neutral-900);\n                --bg-card: var(--brand-navy);\n                --border-card: var(--brand-navy-light);\n                --text-main: rgba(255, 255, 255, 0.85);\n                --text-heading: #ffffff;\n                --bg-blockquote: rgba(232, 192, 161, 0.1);\n                --neutral-100: var(--brand-navy-light);\n            }\n        }\n\n        html,\n        body {\n            margin: 0;\n            padding: 0;\n            box-sizing: border-box;\n            background-color: transparent;\n        }\n\n        body {\n            font-family: var(--font-jost);\n            color: var(--text-main);\n            line-height: 1.6;\n            -webkit-font-smoothing: antialiased;\n            padding: 16px;\n        }\n\n        .adeu-card {\n            background-color: var(--bg-card);\n            border: 1px solid var(--border-card);\n            border-radius: 12px;\n            overflow: hidden;\n            display: flex;\n            flex-direction: column;\n        }\n\n        .navbar {\n            flex-shrink: 0;\n            background-color: var(--bg-card);\n            padding: 16px 32px;\n            border-bottom: 1px solid var(--border-card);\n            display: flex;\n            align-items: center;\n            justify-content: space-between;\n            position: relative;\n        }\n\n        .logo-container {\n            display: flex;\n            align-items: center;\n            flex: 1;\n        }\n\n        .nav-title {\n            position: absolute;\n            left: 50%;\n            transform: translateX(-50%);\n            font-family: var(--font-lora);\n            font-weight: 600;\n            color: var(--text-heading);\n            font-size: 1.1rem;\n            white-space: nowrap;\n            overflow: hidden;\n            text-overflow: ellipsis;\n            max-width: 40%;\n            text-align: center;\n        }\n\n        .nav-actions {\n            display: flex;\n            align-items: center;\n            justify-content: flex-end;\n            flex: 1;\n        }\n\n        #copy-btn {\n            display: none;\n            align-items: center;\n            gap: 6px;\n            background: transparent;\n            border: none;\n            color: var(--text-main);\n            font-family: var(--font-jost);\n            font-size: 0.85rem;\n            font-weight: 500;\n            cursor: pointer;\n            padding: 8px;\n            border-radius: 6px;\n            transition: all 0.2s ease;\n        }\n\n        #copy-btn:hover {\n            color: var(--text-heading);\n            background: var(--neutral-100);\n        }\n\n        #open-btn {\n            display: none;\n            align-items: center;\n            gap: 6px;\n            background: transparent;\n            border: none;\n            color: var(--text-main);\n            font-family: var(--font-jost);\n            font-size: 0.85rem;\n            font-weight: 500;\n            cursor: pointer;\n            padding: 8px;\n            border-radius: 6px;\n            transition: all 0.2s ease;\n        }\n\n        #open-btn:hover {\n            color: var(--text-heading);\n            background: var(--neutral-100);\n        }\n\n        @media (prefers-color-scheme: dark) {\n            #copy-btn:hover {\n                background: var(--brand-navy-light);\n            }\n            #open-btn:hover {\n                background: var(--brand-navy-light);\n            }\n        }\n\n        .logo-container svg {\n            max-width: 80px;\n            height: auto;\n        }\n\n        .logo-container svg path,\n        .logo-container svg rect,\n        .logo-container svg polygon,\n        .logo-container svg circle {\n            transition: fill 0.2s ease;\n        }\n\n        @media (prefers-color-scheme: dark) {\n\n            .logo-container svg path,\n            .logo-container svg rect,\n            .logo-container svg polygon,\n            .logo-container svg circle,\n            .logo-container svg {\n                fill: #ffffff !important;\n            }\n        }\n\n        .content-wrapper {\n            position: relative;\n        }\n\n        .content-wrapper::-webkit-scrollbar {\n            width: 6px;\n        }\n\n        .content-wrapper::-webkit-scrollbar-track {\n            background: transparent;\n        }\n\n        .content-wrapper::-webkit-scrollbar-thumb {\n            background-color: var(--border-card);\n            border-radius: 4px;\n        }\n\n        #app {\n            padding: 32px;\n            display: flow-root;\n        }\n\n        .fade-overlay {\n            position: absolute;\n            bottom: 0;\n            left: 0;\n            right: 0;\n            height: 80px;\n            background: linear-gradient(to bottom, rgba(255, 255, 255, 0), var(--bg-card));\n            pointer-events: none;\n            display: none;\n        }\n\n        @media (prefers-color-scheme: dark) {\n            .fade-overlay {\n                background: linear-gradient(to bottom, rgba(26, 42, 44, 0), var(--bg-card));\n            }\n        }\n\n        .toggle-container {\n            flex-shrink: 0;\n            display: none;\n            justify-content: center;\n            align-items: center;\n            padding: 12px;\n            border-top: 1px solid var(--border-card);\n            background-color: var(--bg-card);\n        }\n\n        #toggle-btn {\n            background: transparent;\n            border: none;\n            color: var(--brand-sand-dark);\n            font-family: var(--font-jost);\n            font-weight: 600;\n            font-size: 0.95rem;\n            cursor: pointer;\n            display: flex;\n            align-items: center;\n            gap: 6px;\n            padding: 8px 16px;\n            border-radius: 6px;\n            transition: all 0.2s ease;\n        }\n\n        #toggle-btn:hover {\n            color: var(--text-heading);\n            background: var(--neutral-100);\n        }\n\n        @media (prefers-color-scheme: dark) {\n            #toggle-btn:hover {\n                background: var(--brand-navy-light);\n            }\n        }\n\n        #toggle-icon {\n            transition: transform 0.3s ease;\n        }\n\n        h1,\n        h2,\n        h3,\n        h4 {\n            font-family: var(--font-lora);\n            color: var(--text-heading);\n            font-weight: 600;\n            letter-spacing: -0.02em;\n            margin-top: 1.5em;\n            margin-bottom: 0.5em;\n        }\n\n        h1 {\n            font-size: 2.25rem;\n            border-bottom: 1px solid var(--border-card);\n            padding-bottom: 0.3em;\n            margin-top: 0;\n        }\n\n        h2 {\n            font-size: 1.75rem;\n        }\n\n        h3 {\n            font-size: 1.25rem;\n        }\n\n        a {\n            color: var(--brand-sand-dark);\n            text-decoration: none;\n            border-bottom: 1px solid transparent;\n            transition: border 0.2s ease;\n        }\n\n        a:hover {\n            border-bottom-color: var(--brand-sand-dark);\n        }\n\n        strong {\n            font-weight: 600;\n            color: var(--text-heading);\n        }\n\n        ul,\n        ol {\n            padding-left: 1.5rem;\n            margin-bottom: 1rem;\n        }\n\n        li {\n            margin-bottom: 0.5rem;\n        }\n\n        blockquote {\n            border-left: 4px solid var(--brand-sand);\n            padding: 12px 20px;\n            margin: 24px 0;\n            color: var(--text-main);\n            background: var(--bg-blockquote);\n            border-radius: 0 8px 8px 0;\n            font-style: italic;\n        }\n\n        code {\n            font-family: ui-monospace, SFMono-Regular, Consolas, \"Liberation Mono\", Menlo, monospace;\n            font-size: 0.85em;\n            background: var(--neutral-100);\n            color: var(--brand-sand-dark);\n            padding: 0.2em 0.4em;\n            border-radius: 4px;\n        }\n\n        pre code {\n            display: block;\n            padding: 16px;\n            background: var(--neutral-900);\n            color: #e5e5e5;\n            border-radius: 8px;\n            overflow-x: auto;\n        }\n\n        .skeleton {\n            background: linear-gradient(90deg, var(--neutral-100) 25%, var(--border-card) 50%, var(--neutral-100) 75%);\n            background-size: 200% 100%;\n            animation: skeleton 1.5s ease-in-out infinite;\n            border-radius: 4px;\n        }\n\n        @keyframes skeleton {\n            0% {\n                background-position: 200% 0;\n            }\n\n            100% {\n                background-position: -200% 0;\n            }\n        }\n\n        .alert {\n            padding: 16px;\n            border-radius: 8px;\n            margin-bottom: 20px;\n            display: flex;\n            flex-direction: column;\n            gap: 8px;\n            background-color: #fef2f2;\n            border: 1px solid #fecaca;\n            color: #991b1b;\n        }\n\n        @media (prefers-color-scheme: dark) {\n            .alert {\n                background-color: rgba(127, 29, 29, 0.2);\n                border-color: rgba(248, 113, 113, 0.3);\n                color: #fca5a5;\n            }\n        }\n\n        .alert-title {\n            font-weight: 600;\n            font-size: 1.1em;\n            margin: 0;\n            display: flex;\n            align-items: center;\n            gap: 8px;\n            font-family: var(--font-lora);\n        }\n\n        .alert-body {\n            margin: 0;\n            font-size: 0.95em;\n        }\n\n        .alert-details {\n            background: rgba(0, 0, 0, 0.05);\n            padding: 12px;\n            border-radius: 6px;\n            font-family: ui-monospace, Consolas, monospace;\n            font-size: 0.85em;\n            white-space: pre-wrap;\n            word-break: break-all;\n            margin-top: 8px;\n            border: 1px solid rgba(0, 0, 0, 0.1);\n        }\n    </style>\n    <script id=\"marked-script\">/**\n * marked v15.0.12 - a markdown parser\n * Copyright (c) 2011-2025, Christopher Jeffrey. (MIT Licensed)\n * https://github.com/marked